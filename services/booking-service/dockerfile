FROM maven:3.8.4-jdk-8 AS build

WORKDIR /build
COPY mvnw ./
COPY pom.xml ./
COPY .mvn ./

RUN mvn -B dependency:go-offline
COPY src ./src
RUN mvn -B package -DskipTests

FROM openjdk:8-jdk-alpine
WORKDIR /serv
RUN apk add --no-cache bash
COPY --from=build /build/target/*.jar app.jar
COPY wait-for-it.sh ./
RUN chmod +x wait-for-it.sh
EXPOSE 8083
CMD ["./wait-for-it.sh", "-t", "30", "postgres:5432", "--", \
    "./wait-for-it.sh", "-t", "30", "rabbitmq:5672", "--", \
    "./wait-for-it.sh", "-t", "30", "hotel-service:8082", "--", \
    "./wait-for-it.sh", "-t", "30", "payment-service:8084", "--", \
    "./wait-for-it.sh", "-t", "30", "loyalty-service:8085", "--", \
     "java", "-jar", "app.jar"]